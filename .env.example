# ClipShare Environment Configuration

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=clipshare
DB_PASSWORD=clipshare123
DB_NAME=clipshare
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RustFS (S3-Compatible Storage) Configuration
RUSTFS_ENDPOINT=localhost:9000
RUSTFS_PUBLIC_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=clipshare
RUSTFS_SECRET_KEY=clipshare123
RUSTFS_USE_SSL=false

# JWT Configuration
JWT_SECRET=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=168h
MAGIC_LINK_EXPIRY=15m
REQUIRE_EMAIL_VERIFY=true

# Email Configuration (for magic links)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@clipshare.io
EMAIL_FROM_NAME=ClipShare
EMAIL_USE_TLS=true

# Instance Settings
INSTANCE_NAME=ClipShare
INSTANCE_URL=https://clipshare.io
ALLOW_SIGNUPS=true
MAX_CLIP_DURATION_SECONDS=300
DEFAULT_CLIP_LIFETIME_DAYS=
MAX_UPLOAD_SIZE_BYTES=1073741824
CUSTOM_DOMAINS_ENABLED=false
WILDCARD_DOMAIN=*.clipshare.io
