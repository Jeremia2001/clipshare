# ClipShare Docker Compose configuration.
# Copy to .env (in this same directory) and edit before running
# `docker compose up`. Every key below is optional — anything you leave out
# falls back to the default baked into docker-compose.yml.

# -------- Environment --------
# `production` enables the one-time admin setup-token flow. `development`
# seeds a dev user and bypasses auth — never use it for a real deployment.
ENV=development

# Public URL users point the desktop app at. Must be reachable from clients.
SERVER_PUBLIC_URL=http://localhost:8080

# -------- Secrets (change these for production) --------
# Generate with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Postgres credentials (used for both the postgres container and the API).
DB_USER=clipshare
DB_PASSWORD=clipshare123
DB_NAME=clipshare

# S3 credentials. For local dev (rustfs container) the defaults below work.
# For OVH S3 set RUSTFS_ENDPOINT to your OVH S3 region endpoint, e.g.:
#   RUSTFS_ENDPOINT=s3.gra.perf.cloud.ovh.net
#   RUSTFS_ACCESS_KEY=<OVH S3 access key>
#   RUSTFS_SECRET_KEY=<OVH S3 secret key>
#   RUSTFS_USE_SSL=true
RUSTFS_ENDPOINT=rustfs:9000
RUSTFS_ACCESS_KEY=clipshare
RUSTFS_SECRET_KEY=clipshare123

# -------- Optional --------
# Public URL for presigned download links. Required when the S3 endpoint is
# not directly reachable by clients (e.g. internal hostname). For OVH S3
# this can be left empty — the endpoint is already public.
RUSTFS_PUBLIC_ENDPOINT=
RUSTFS_USE_SSL=false

# Bucket names. The server creates them automatically if the credentials
# allow it; otherwise create them manually before starting the stack.
# RUSTFS_BUCKET_CLIPS=clips
# RUSTFS_BUCKET_THUMBNAILS=thumbnails

# JWT lifetime for admin sessions. Device tokens never expire.
ACCESS_TOKEN_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=168h
